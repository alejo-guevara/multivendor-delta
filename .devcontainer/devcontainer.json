{
  "name": "ContainerLab — Multivendor Delta Lab",

  "image": "ghcr.io/srl-labs/containerlab/devcontainer-dood:latest",

  "runArgs": [
    "--network=host",
    "--pid=host",
    "--privileged"
  ],

  "mounts": [
    "type=bind,src=/var/run/docker.sock,dst=/var/run/docker.sock",
    "type=bind,src=/var/run/netns,dst=/var/run/netns",
    "type=bind,src=/var/lib/docker/containers,dst=/var/lib/docker/containers",
    "type=bind,src=/lib/modules,dst=/lib/modules"
  ],

  "onCreateCommand": "sudo groupadd -f clab_admins && sudo usermod -aG clab_admins,docker $(whoami)",

  "postCreateCommand": "bash .devcontainer/install.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "srl-labs.vscode-containerlab",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "yaml.schemas": {
          "https://containerlab.dev/schema/clab.schema.json": "*.clab.yml"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "containerlab.node.execCommandMapping": {
          "nokia_srlinux": "sr_cli"
        },
        "containerlab.node.sshUserMapping": {
          "nokia_srlinux": "admin"
        }
      }
    }
  },

  "forwardPorts": [3000, 9090, 3080],

  "portsAttributes": {
    "3000": {
      "label": "Grafana",
      "onAutoForward": "openBrowser"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "notify"
    },
    "3080": {
      "label": "ContainerLab Graph",
      "onAutoForward": "notify"
    }
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  }
}
