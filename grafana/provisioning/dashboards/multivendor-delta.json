{
  "title": "Multivendor Delta Lab — Traffic & Telemetry",
  "uid": "multivendor-delta",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "🔀 Path Selection — Active Route",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "srl_if_statistics_in_packets{interface_name='ethernet-1_2'}",
          "legendFormat": "1-hop (SRL→CVX) pkts/s"
        },
        {
          "expr": "srl_if_statistics_in_packets{interface_name='ethernet-1_1'}",
          "legendFormat": "2-hop (SRL→FRR) pkts/s"
        }
      ]
    },

    {
      "id": 2,
      "title": "📊 Ixia TX vs RX Frame Rate (pps)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "TX (Ixia eth1)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "RX (Ixia eth2)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "rate(srl_if_statistics_out_packets{interface_name='ethernet-1_3'}[30s])",
          "legendFormat": "TX (Ixia eth1)"
        },
        {
          "expr": "rate(srl_if_statistics_in_packets{interface_name='ethernet-1_3'}[30s])",
          "legendFormat": "RX (Ixia eth2 via CVX)"
        }
      ]
    },

    {
      "id": 3,
      "title": "🔗 SR Linux Interface Traffic (bps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bps" }
      },
      "targets": [
        {
          "expr": "rate(srl_if_statistics_out_octets{interface_name='ethernet-1_1'}[30s])*8",
          "legendFormat": "e1-1 → FRR (2-hop TX)"
        },
        {
          "expr": "rate(srl_if_statistics_out_octets{interface_name='ethernet-1_2'}[30s])*8",
          "legendFormat": "e1-2 → Cumulus (1-hop TX)"
        },
        {
          "expr": "rate(srl_if_statistics_in_octets{interface_name='ethernet-1_3'}[30s])*8",
          "legendFormat": "e1-3 ← Ixia TX port"
        },
        {
          "expr": "rate(srl_if_statistics_in_octets{interface_name='ethernet-1_4'}[30s])*8",
          "legendFormat": "e1-4 ← Alpine iPerf TX"
        }
      ]
    },

    {
      "id": 4,
      "title": "🤝 BGP Session States",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "established": { "text": "✅ ESTABLISHED", "color": "green" } } },
            { "type": "value", "options": { "active": { "text": "⚠️ ACTIVE", "color": "yellow" } } },
            { "type": "value", "options": { "idle": { "text": "❌ IDLE", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "srl_bgp_neighbor_session_state{peer_address='10.255.0.2'}",
          "legendFormat": "SRL → FRR"
        },
        {
          "expr": "srl_bgp_neighbor_session_state{peer_address='10.255.0.3'}",
          "legendFormat": "SRL → Cumulus"
        }
      ]
    },

    {
      "id": 5,
      "title": "🗺️ OSPF Neighbor Count (SR Linux)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "srl_ospf_instance_statistics_total_neighbors{instance_name='main'}",
          "legendFormat": "OSPF Neighbors"
        }
      ]
    },

    {
      "id": 6,
      "title": "📦 BGP Prefixes Received",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "srl_bgp_neighbor_received_routes{peer_address='10.255.0.2'}",
          "legendFormat": "From FRR"
        },
        {
          "expr": "srl_bgp_neighbor_received_routes{peer_address='10.255.0.3'}",
          "legendFormat": "From Cumulus"
        }
      ]
    },

    {
      "id": 7,
      "title": "🌐 Topology — IP Addressing Reference",
      "type": "text",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "options": {
        "mode": "markdown",
        "content": "## Delta Topology — IP Plan\n\n```\n             [FRR — 10.255.0.2]\n            /   10.0.2.0/30    \\\n    10.0.2.1      10.0.2.5      10.0.2.6\n          /                         \\\n  [SR Linux]  ──10.0.2.8/30──  [Cumulus]\n  10.255.0.1                   10.255.0.3\n   e1-3|e1-4                   swp3|swp4\n       |                           |\n  [Ixia eth1]           [Ixia eth2 / Alpine RX]\n   10.0.1.2/30              10.0.3.2/30\n  [Alpine TX]\n   10.0.10.2/30\n```\n\n**AS:** 65000 (iBGP full mesh)\n**OSPF Area:** 0.0.0.0\n**Loopbacks:** 10.255.0.x/32"
      }
    },

    {
      "id": 8,
      "title": "⚡ Packet Loss — Ixia Flow",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - (rate(srl_if_statistics_in_packets{interface_name='ethernet-1_3'}[30s]) / rate(srl_if_statistics_out_packets{interface_name='ethernet-1_3'}[30s])))",
          "legendFormat": "Estimated Loss %"
        }
      ]
    },

    {
      "id": 9,
      "title": "🔁 1-hop vs 2-hop — Interface Load Comparison",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "bps" }
      },
      "targets": [
        {
          "expr": "rate(srl_if_statistics_out_octets{interface_name='ethernet-1_2'}[30s])*8",
          "legendFormat": "1-hop path (SRL→CVX direct)"
        },
        {
          "expr": "rate(srl_if_statistics_out_octets{interface_name='ethernet-1_1'}[30s])*8",
          "legendFormat": "2-hop path (SRL→FRR→CVX)"
        }
      ]
    }

  ]
}
