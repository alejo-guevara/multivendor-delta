{
  "title": "Multivendor Delta Lab \u2014 Traffic & Telemetry",
  "uid": "multivendor-delta",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "\ud83d\udd00 Path Selection \u2014 Active Route",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_packets{interface_name='ethernet-1/2'}[30s])",
          "legendFormat": "1-hop (SRL\u2192CVX) pkts/s"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_packets{interface_name='ethernet-1/1'}[30s])",
          "legendFormat": "2-hop (SRL\u2192FRR) pkts/s"
        }
      ],
      "description": ""
    },
    {
      "id": 2,
      "title": "\ud83d\udcca iPerf TX \u2014 Frame Rate (pps)",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "TX (Ixia eth1)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "RX (Ixia eth2)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2CC0C",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_packets{interface_name='ethernet-1/3'}[30s])",
          "legendFormat": "TX (iPerf TX (e1-3))"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_packets{interface_name='ethernet-1/3'}[30s])",
          "legendFormat": "RX (iPerf RX (via Cumulus))"
        }
      ],
      "description": ""
    },
    {
      "id": 3,
      "title": "\ud83d\udd17 SR Linux Interface Traffic (bps)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "targets": [
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_octets{interface_name='ethernet-1/1'}[30s])*8",
          "legendFormat": "e1-1 \u2192 FRR (2-hop TX)"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_octets{interface_name='ethernet-1/2'}[30s])*8",
          "legendFormat": "e1-2 \u2192 Cumulus (1-hop TX)"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_octets{interface_name='ethernet-1/3'}[30s])*8",
          "legendFormat": "e1-3 \u2190 iPerf TX"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_octets{interface_name='ethernet-1/3'}[30s])*8",
          "legendFormat": "e1-4 \u2190 Alpine iPerf TX"
        }
      ],
      "description": ""
    },
    {
      "id": 4,
      "title": "\ud83e\udd1d BGP Session States",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "established": {
                  "text": "\u2705 ESTABLISHED",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "active": {
                  "text": "\u26a0\ufe0f ACTIVE",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "idle": {
                  "text": "\u274c IDLE",
                  "color": "red"
                }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "srl_bgp_stats_srl_nokia_network_instance_network_instance_protocols_srl_nokia_bgp_bgp_neighbor_peer_as{peer_address='10.255.0.2'}",
          "legendFormat": "FRR (10.255.0.2) \u2014 AS{{value}}"
        },
        {
          "expr": "srl_bgp_stats_srl_nokia_network_instance_network_instance_protocols_srl_nokia_bgp_bgp_neighbor_peer_as{peer_address='10.255.0.3'}",
          "legendFormat": "Cumulus (10.255.0.3) \u2014 AS{{value}}"
        }
      ],
      "description": ""
    },
    {
      "id": 5,
      "title": "\ud83d\uddfa\ufe0f OSPF Neighbor Count (SR Linux)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_packets{interface_name=~'ethernet-1/1|ethernet-1/2'})",
          "legendFormat": "OSPF Neighbors"
        }
      ],
      "description": ""
    },
    {
      "id": 6,
      "title": "\ud83d\udce6 BGP Prefixes Received",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "srl_bgp_stats_srl_nokia_network_instance_network_instance_protocols_srl_nokia_bgp_bgp_neighbor_received_messages_total_updates{peer_address='10.255.0.2'}",
          "legendFormat": "From FRR"
        },
        {
          "expr": "srl_bgp_stats_srl_nokia_network_instance_network_instance_protocols_srl_nokia_bgp_bgp_neighbor_received_messages_total_updates{peer_address='10.255.0.3'}",
          "legendFormat": "From Cumulus"
        }
      ],
      "description": ""
    },
    {
      "id": 7,
      "title": "\ud83c\udf10 Topology \u2014 IP Addressing Reference",
      "type": "text",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "options": {
        "mode": "markdown",
        "content": "## Delta Topology \u2014 IP Plan\n\n```\n             [FRR \u2014 10.255.0.2]\n            /   10.0.2.0/30    \\\n    10.0.2.1      10.0.2.5      10.0.2.6\n          /                         \\\n  [SR Linux]  \u2500\u250010.0.2.8/30\u2500\u2500  [Cumulus]\n  10.255.0.1                   10.255.0.3\n   e1-3|e1-4                   swp3|swp4\n       |                           |\n  [Ixia eth1]           [Ixia eth2 / Alpine RX]\n   10.0.1.2/30              10.0.3.2/30\n  [Alpine TX]\n   10.0.10.2/30\n```\n\n**AS:** 65000 (iBGP full mesh)\n**OSPF Area:** 0.0.0.0\n**Loopbacks:** 10.255.0.x/32"
      },
      "description": ""
    },
    {
      "id": 8,
      "title": "\u26a1 Packet Loss \u2014 Ixia Flow",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - clamp_min(rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_in_packets{interface_name='ethernet-1/3'}[30s]), 0.001) / clamp_min(rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_packets{interface_name='ethernet-1/3'}[30s]), 0.001))",
          "legendFormat": "Estimated Loss %"
        }
      ],
      "description": ""
    },
    {
      "id": 9,
      "title": "\ud83d\udd01 1-hop vs 2-hop \u2014 Interface Load Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "targets": [
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_octets{interface_name='ethernet-1/2'}[30s])*8",
          "legendFormat": "1-hop path (SRL\u2192CVX direct)"
        },
        {
          "expr": "rate(srl_if_stats_srl_nokia_interfaces_interface_statistics_out_octets{interface_name='ethernet-1/1'}[30s])*8",
          "legendFormat": "2-hop path (SRL\u2192FRR\u2192CVX)"
        }
      ],
      "description": ""
    }
  ]
}