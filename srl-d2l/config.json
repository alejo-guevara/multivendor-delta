{
  "srl_nokia-network-instance:network-instance": [
    {
      "name": "default",
      "admin-state": "enable",
      "srl_nokia-interfaces:interface": [
        { "name": "ethernet-1/1" },
        { "name": "ethernet-1/2" },
        { "name": "ethernet-1/3" },
        { "name": "ethernet-1/4" },
        { "name": "lo0" }
      ],
      "srl_nokia-ospf:ospf": {
        "instance": [
          {
            "name": "main",
            "admin-state": "enable",
            "version": "ospf-v2",
            "router-id": "10.255.0.1",
            "area": [
              {
                "area-id": "0.0.0.0",
                "interface": [
                  {
                    "interface-name": "ethernet-1/1.0",
                    "interface-type": "point-to-point",
                    "admin-state": "enable"
                  },
                  {
                    "interface-name": "ethernet-1/2.0",
                    "interface-type": "point-to-point",
                    "admin-state": "enable"
                  },
                  {
                    "interface-name": "lo0.0",
                    "passive": true,
                    "admin-state": "enable"
                  }
                ]
              }
            ]
          }
        ]
      },
      "srl_nokia-bgp:bgp": {
        "admin-state": "enable",
        "autonomous-system": 65000,
        "router-id": "10.255.0.1",
        "group": [
          {
            "group-name": "ibgp-peers",
            "admin-state": "enable",
            "peer-as": 65000,
            "local-as": [{ "as-number": 65000 }],
            "transport": { "local-address": "10.255.0.1" },
            "timers": { "connect-retry": 10 },
            "afi-safi": [
              {
                "afi-safi-name": "ipv4-unicast",
                "admin-state": "enable"
              }
            ]
          }
        ],
        "neighbor": [
          {
            "peer-address": "10.255.0.2",
            "admin-state": "enable",
            "peer-group": "ibgp-peers",
            "description": "FRR"
          },
          {
            "peer-address": "10.255.0.3",
            "admin-state": "enable",
            "peer-group": "ibgp-peers",
            "description": "Cumulus VX"
          }
        ]
      }
    }
  ],
  "srl_nokia-interfaces:interface": [
    {
      "name": "ethernet-1/1",
      "admin-state": "enable",
      "description": "Link to FRR eth1",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [{ "ip-prefix": "10.0.2.1/30" }]
          }
        }
      ]
    },
    {
      "name": "ethernet-1/2",
      "admin-state": "enable",
      "description": "Link to Cumulus swp2 (1-hop shortcut)",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [{ "ip-prefix": "10.0.2.9/30" }]
          }
        }
      ]
    },
    {
      "name": "ethernet-1/3",
      "admin-state": "enable",
      "description": "Ixia TX port eth1",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [{ "ip-prefix": "10.0.1.1/30" }]
          }
        }
      ]
    },
    {
      "name": "ethernet-1/4",
      "admin-state": "enable",
      "description": "Alpine iPerf TX",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [{ "ip-prefix": "10.0.10.1/30" }]
          }
        }
      ]
    },
    {
      "name": "lo0",
      "admin-state": "enable",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [{ "ip-prefix": "10.255.0.1/32" }]
          }
        }
      ]
    },
    {
      "name": "mgmt0",
      "admin-state": "enable",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": { "admin-state": "enable", "dhcp-client": {} }
        }
      ]
    }
  ]
}
